generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ═══════════════════════════════════════════════════════════════════════
// Modelo de Dados Core - Pontufy B2B MVP
// ═══════════════════════════════════════════════════════════════════════

model Tenant {
  id              String   @id @default(uuid())
  name            String
  customLogoUrl   String?
  sector          String   // e.g., 'tech', 'health', 'retail', 'industry'
  contractStatus  String   @default("active") // 'active', 'suspended', 'cancelled'
  aiCredits       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relacionamentos
  users           User[]
  courses         Course[]
  pointsLedger    PointsLedger[]
  rewards         Reward[]
}

model User {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  email           String   @unique
  role            String   @default("employee") // 'admin_rh', 'employee'
  pointsBalance   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  pointsLedger    PointsLedger[]

  @@index([tenantId])
}

model Course {
  id              String   @id @default(uuid())
  tenantId        String
  title           String
  description     String?
  aiCreditsSpent  Int      @default(0)
  status          String   @default("draft") // 'draft', 'published'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  lessons         Lesson[]

  @@index([tenantId])
}

model Lesson {
  id              String   @id @default(uuid())
  courseId        String
  title           String
  type            String   // 'video', 'text'
  contentUrl      String?
  pointsAssigned  Int      @default(0) // Quantos pontos essa aula vale
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model PointsLedger {
  id              String   @id @default(uuid())
  userId          String
  tenantId        String
  type            String   // 'gain', 'loss'
  pointsAmount    Int
  description     String
  timestamp       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

model Reward {
  id              String   @id @default(uuid())
  tenantId        String?  // Nulo se for um prêmio global disponível para todos. Preenchido se for customizado por empresa.
  partnerStore    String   // 'amazon', 'magalu', 'shopee', 'mercadolivre'
  title           String
  affiliateLink   String
  pricePoints     Int
  isActive        Boolean  @default(true) // Permite o RH ligar/desligar
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}
