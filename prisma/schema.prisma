generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════
// Modelo de Dados Core - Pontufy B2B MVP
// ═══════════════════════════════════════════════════════════════════════

model Tenant {
  id              String   @id @default(uuid())
  name            String
  customLogoUrl   String?
  sector          String   // 'tech', 'health', 'retail', 'industry'
  contractStatus  String   @default("active") // 'active', 'suspended', 'cancelled'
  aiCredits       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  courses         Course[]
  pointsLedger    PointsLedger[]
  rewards         Reward[]
  invitations     Invitation[]
}

model User {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  email           String   @unique
  passwordHash    String?  // scrypt: "<salt>:<hash>". Null only for legacy/migrated accounts.
  role            String   @default("employee") // 'admin_rh', 'employee', 'guest'
  pointsBalance   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  pointsLedger      PointsLedger[]
  lessonCompletions LessonCompletion[]
  passwordReset     PasswordReset?

  @@index([tenantId])
}

model Course {
  id              String   @id @default(uuid())
  tenantId        String
  title           String
  description     String?
  aiCreditsSpent  Int      @default(0)
  status          String   @default("draft") // 'draft', 'published'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  lessons         Lesson[]

  @@index([tenantId])
}

model Lesson {
  id              String   @id @default(uuid())
  courseId        String
  title           String
  type            String   // 'video', 'text'
  contentUrl      String?
  pointsAssigned  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completions LessonCompletion[]

  @@index([courseId])
}

model LessonCompletion {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model PointsLedger {
  id              String   @id @default(uuid())
  userId          String
  tenantId        String
  type            String   // 'gain', 'loss'
  pointsAmount    Int
  description     String
  timestamp       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

model Reward {
  id              String   @id @default(uuid())
  tenantId        String?  // Null = global reward available to all tenants.
  partnerStore    String   // 'amazon', 'magalu', 'shopee', 'mercadolivre'
  title           String
  affiliateLink   String
  pricePoints     Int
  imageUrl        String?
  category        String?  // 'tech', 'health', 'home', 'coupons'
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @unique
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Invitation {
  id        String   @id @default(uuid())
  tenantId  String
  email     String
  token     String   @unique
  role      String   @default("employee") // 'admin_rh', 'employee', 'guest'
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([token])
}
