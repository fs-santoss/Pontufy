AUTH_SECRET="generate-with-openssl-rand-base64-32"

# === Banco de Dados (PostgreSQL — Supabase recomendado) ===
# Configurações > Database > Connection string (Transaction pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
# Connection string (Direct — usado por migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# === Motor de IA para Geração de Cursos ===
# Configure pelo menos UMA chave para habilitar geração inteligente.
# Sem nenhuma chave, o sistema usa templates genéricos.
# Ordem de prioridade: Gemini > OpenAI > Anthropic

# Google Gemini (RECOMENDADO — gratuito em aistudio.google.com/app/apikey)
GEMINI_API_KEY=""

# OpenAI (platform.openai.com/api-keys)
# OPENAI_API_KEY=""

# Anthropic Claude (console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=""
