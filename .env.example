# ─── Required ────────────────────────────────────────────────────────────────

# Signs NextAuth session JWTs. MANDATORY in production — without it, tokens can
# be forged. Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# PostgreSQL connection. On serverless (Vercel) DATABASE_URL must be a POOLED
# endpoint (PgBouncer / Neon pooler / Supabase pooler on port 6543), e.g.:
#   postgresql://user:pass@host:6543/db?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@host:6543/pontufy?pgbouncer=true&connection_limit=1"

# Direct (unpooled) connection used by `prisma migrate`. Point at the direct
# host/port (5432). With a single non-pooled Postgres, set it equal to DATABASE_URL.
DIRECT_URL="postgresql://user:password@host:5432/pontufy"

# ─── Optional integrations (features degrade gracefully if unset) ─────────────

# Canonical app URL (used for password-reset / setup links in emails).
# NEXTAUTH_URL="https://app.yourdomain.com"

# Transactional email (Resend). Without it, emails are logged to the console.
# RESEND_API_KEY=""
# EMAIL_FROM="Pontufy <noreply@pontufy.com>"

# AI course generation — the first configured provider is used.
# Ordem de prioridade: Gemini > OpenAI > Anthropic
# GEMINI_API_KEY=""
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""

# Async course-generation queue (Upstash QStash).
# QSTASH_TOKEN=""
# QSTASH_CURRENT_SIGNING_KEY=""
# QSTASH_NEXT_SIGNING_KEY=""
# QSTASH_WORKER_URL="https://app.yourdomain.com/api/webhooks/queue-worker"

# Caching & rate limiting (Upstash Redis).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Stripe payments.
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# Affiliate network (Lomadee).
# LOMADEE_APP_TOKEN=""
# LOMADEE_SOURCE_ID=""

# Protects cron endpoints (Authorization: Bearer <CRON_SECRET>).
# CRON_SECRET=""
