AUTH_SECRET="generate-with-openssl-rand-base64-32"
DATABASE_URL="file:./dev.db"

# === Motor de IA para Geração de Cursos ===
# Configure pelo menos UMA chave para habilitar geração inteligente.
# Sem nenhuma chave, o sistema usa templates genéricos.
# Ordem de prioridade: Gemini > OpenAI > Anthropic

# Google Gemini (RECOMENDADO — gratuito em aistudio.google.com/app/apikey)
GEMINI_API_KEY=""

# OpenAI (platform.openai.com/api-keys)
# OPENAI_API_KEY=""

# Anthropic Claude (console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=""
